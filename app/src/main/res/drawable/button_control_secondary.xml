<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#33495B68" />
            <stroke
                android:width="1dp"
                android:color="#7DAEC2CF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#2A3642" />
            <stroke
                android:width="1dp"
                android:color="#5D9AB1C0" />
        </shape>
    </item>
</selector>
