<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#12364A57"
                android:startColor="#1AFFFFFF" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#3E95A6B8" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#0BFFFFFF"
                android:startColor="#15FFFFFF" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#2E95A6B8" />
        </shape>
    </item>
</selector>
