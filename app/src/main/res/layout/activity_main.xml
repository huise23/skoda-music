<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="86dp"
        android:layout_height="match_parent"
        android:background="@drawable/panel_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp">

        <Button
            android:id="@+id/nav_home"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_nav_icon_active"
            android:fontFamily="sans-serif-medium"
            android:text="⌂"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <Button
            android:id="@+id/nav_queue"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_nav_icon_inactive"
            android:fontFamily="sans-serif-medium"
            android:text="☰"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="24sp" />

        <Button
            android:id="@+id/nav_library"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_nav_icon_inactive"
            android:fontFamily="sans-serif-medium"
            android:text="▦"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="24sp" />

        <Button
            android:id="@+id/nav_settings"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_nav_icon_inactive"
            android:fontFamily="sans-serif-medium"
            android:text="⚙"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="24sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="12dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/build_id_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginRight="8dp"
            android:background="@drawable/field_surface"
            android:fontFamily="monospace"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="@string/build_id_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <ScrollView
            android:id="@+id/page_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_card"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/track_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="marquee"
                            android:fontFamily="sans-serif-medium"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:gravity="start|center_vertical"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:maxLines="1"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:text="@string/track_not_loaded"
                            android:textColor="@color/text_primary"
                            android:textSize="36sp" />

                        <TextView
                            android:id="@+id/playback_value"
                            android:layout_width="1dp"
                            android:layout_height="1dp"
                            android:text="@string/status_paused"
                            android:visibility="gone" />

                        <SeekBar
                            android:id="@+id/playback_seek_bar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/playback_progress_value"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="monospace"
                                android:text="@string/playback_progress_placeholder"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/playback_duration_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="@string/playback_progress_placeholder"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/download_progress_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="monospace"
                            android:text="@string/download_progress_placeholder"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_prev"
                                android:layout_width="78dp"
                                android:layout_height="78dp"
                                android:background="@drawable/button_control_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:text="⏮"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="24sp" />

                            <Space
                                android:layout_width="34dp"
                                android:layout_height="1dp" />

                            <Button
                                android:id="@+id/btn_play_pause"
                                android:layout_width="98dp"
                                android:layout_height="98dp"
                                android:background="@drawable/button_control_primary"
                                android:fontFamily="sans-serif-medium"
                                android:text="▶"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="30sp" />

                            <Space
                                android:layout_width="34dp"
                                android:layout_height="1dp" />

                            <Button
                                android:id="@+id/btn_next"
                                android:layout_width="78dp"
                                android:layout_height="78dp"
                                android:background="@drawable/button_control_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:text="⏭"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <Space
                        android:layout_width="14dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:background="@drawable/field_surface"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_home_tab_recommend"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/button_primary"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/home_tab_recommend"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="1dp" />

                            <Button
                                android:id="@+id/btn_home_tab_lyrics"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/button_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/home_tab_lyrics"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/home_recommend_panel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/home_recommend_list_title"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/home_recommend_preview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="monospace"
                                android:lineSpacingExtra="1dp"
                                android:maxLines="7"
                                android:text="@string/home_recommend_placeholder"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btn_recommend_home"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/button_secondary"
                                android:fontFamily="sans-serif-medium"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:text="@string/action_recommend_listen"
                                android:textAllCaps="false"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/home_lyrics_panel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/home_lyrics_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:lineSpacingExtra="3dp"
                                android:maxLines="11"
                                android:text="@string/home_lyrics_placeholder"
                                android:textColor="@color/text_secondary"
                                android:textSize="17sp" />

                            <TextView
                                android:id="@+id/runtime_log_label"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/label_runtime_logs"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/runtime_log_preview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/field_surface"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="monospace"
                                android:maxLines="4"
                                android:minHeight="72dp"
                                android:padding="12dp"
                                android:text="@string/runtime_logs_empty"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_cover_entry"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/track_label"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/playback_label"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_queue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_queue"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_recommend_queue"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/action_recommend_queue"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <Button
                            android:id="@+id/btn_clear_queue"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/action_clear_queue"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/queue_tracks_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_library"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_library"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/library_search_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_library_search"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/library_tracks_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_service_config"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/emby_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_emby"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/emby_base_url_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_emby_base_url"
                        android:imeOptions="actionNext"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_cf_ref_domain"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/cf_ref_domain_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_cf_ref_domain"
                        android:imeOptions="actionNext"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/label_cf_ref_note"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/emby_username_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_emby_username"
                        android:imeOptions="actionNext"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/emby_password_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_emby_password"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/emby_auth_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/label_emby_auth_note"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btn_test_emby"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_primary"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/action_test_emby"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/emby_status_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/emby_status_not_tested"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/lrcapi_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/label_lrcapi"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/lrcapi_base_url_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_surface"
                        android:fontFamily="sans-serif"
                        android:hint="@string/hint_lrcapi_base_url"
                        android:imeOptions="actionDone"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btn_test_lrcapi"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/action_test_lrcapi"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/lrcapi_status_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/lrcapi_status_not_tested"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</LinearLayout>
